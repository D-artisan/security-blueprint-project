# === SENSITIVE DATA - NEVER COMMIT ===
# Encryption keys and vault
.keyvault/
*.key
*.pem
*.crt
*.p12
*.pfx

# AWS credentials
.aws/
credentials
*.credentials

# Environment variables with secrets
.env
.env.local
.env.*.local

# === PYTHON ===
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv/
.conda/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# === NODE.JS / CLOUDFLARE WORKERS ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/

# Wrangler build outputs
worker/dist/
worker/.wrangler/
.dev.vars

# === LOGS AND RUNTIME DATA ===
# Application logs
*.log
*.txt
*.jsonl

# Audit trails (may contain sensitive data)
audit.jsonl
incidents.jsonl
pillar4_compliance/audit.jsonl
pillar6-response/incidents.jsonl
pillar6-response/response_log.txt
pillar6-response/revoked_users.json

# === GENERATED REPORTS ===
# May contain discovered sensitive data
*_report.json
discovery_report.json
compliance_report.json

# === DOCKER ===
# Docker volumes and data
.docker/
docker-compose.override.yml

# === DATABASES ===
*.db
*.sqlite
*.sqlite3

# === IDE / EDITOR ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === TEMPORARY FILES ===
*.tmp
*.temp
*.cache
.cache/

# === KUBERNETES / VELERO ===
# Kubeconfig with sensitive cluster access
kubeconfig
*.kubeconfig

# === OBSERVABILITY DATA ===
